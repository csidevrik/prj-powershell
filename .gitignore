# --- DeletePrefixFiles: solo excluir artefactos generados ---
# El código fuente SÍ se versiona. Lo que se ignora son entornos y builds.
/DeletePrefixFiles/.venv/
/DeletePrefixFiles/build/
/DeletePrefixFiles/dist/
/DeletePrefixFiles/__pycache__/
/DeletePrefixFiles/DeletePrefixFiles/

# General Python ignores
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pdb
*.egg-info/
*.egg
build/
dist/
.eggs/
*.log

# Virtualenv / environment folders
venv/
.venv/
ENV/
env/

# IDE & editor
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# OS files
.DS_Store
Thumbs.db

# --- Outputs de scripts (datos generados, no código fuente) ---
# Resultados de webscraping (archivos CSV, debug, raw generados por los scripts)
python/webscraping/*.csv
python/webscraping/*.debug.*
python/webscraping/*.raw.txt

# Resultados de escaneos de red
pwsh/Networkutils/reporte_red.csv
pwsh/Networkutils/resultado.xml

# --- Node.js (sin package.json activo) ---
package-lock.json
node_modules/
